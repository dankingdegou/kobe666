<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="safe_city_inspection_robot">
  <xacro:property name="base_length" value="0.265"/>
  <xacro:property name="base_width" value="0.265"/>
  <xacro:property name="base_height" value="0.089"/>
  <xacro:property name="wheel_radius" value="0.033"/>
  <xacro:property name="wheel_width" value="0.018"/>
  <xacro:property name="wheel_y" value="0.144"/>

  <material name="patrol_blue">
    <color rgba="0.06 0.23 0.36 1.0"/>
  </material>
  <material name="safety_cyan">
    <color rgba="0.05 0.85 0.95 1.0"/>
  </material>
  <material name="wheel_black">
    <color rgba="0.02 0.02 0.025 1.0"/>
  </material>
  <material name="sensor_dark">
    <color rgba="0.01 0.01 0.012 1.0"/>
  </material>

  <link name="base_footprint"/>

  <link name="base_link">
    <visual name="waffle_base">
      <origin xyz="-0.064 0 0.048" rpy="0 0 0"/>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
      <material name="patrol_blue"/>
    </visual>
    <visual name="patrol_top_shell">
      <origin xyz="-0.064 0 0.108" rpy="0 0 0"/>
      <geometry>
        <box size="0.24 0.22 0.045"/>
      </geometry>
      <material name="patrol_blue"/>
    </visual>
    <visual name="status_light">
      <origin xyz="0.045 0 0.16" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.028" length="0.025"/>
      </geometry>
      <material name="safety_cyan"/>
    </visual>
    <collision name="base_collision">
      <origin xyz="-0.064 0 0.048" rpy="0 0 0"/>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="-0.064 0 0.048" rpy="0 0 0"/>
      <mass value="1.0"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.010" rpy="0 0 0"/>
  </joint>

  <link name="wheel_left_link">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
      <material name="wheel_black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="wheel_left_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_left_link"/>
    <origin xyz="0 ${wheel_y} 0.023" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="wheel_right_link">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
      <material name="wheel_black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="wheel_right_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_right_link"/>
    <origin xyz="0 -${wheel_y} 0.023" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="base_scan">
    <visual name="rplidar_visual">
      <origin xyz="-0.064 0 0.121" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.0508" length="0.055"/>
      </geometry>
      <material name="sensor_dark"/>
    </visual>
  </link>

  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="base_scan"/>
    <origin xyz="-0.064 0 0.121" rpy="0 0 0"/>
  </joint>

  <link name="camera_link">
    <visual name="rgb_camera_visual">
      <origin xyz="0.095 0 0.135" rpy="0 0 0"/>
      <geometry>
        <box size="0.045 0.080 0.035"/>
      </geometry>
      <material name="sensor_dark"/>
    </visual>
  </link>

  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin xyz="0.064 -0.065 0.094" rpy="0 0 0"/>
  </joint>
</robot>
