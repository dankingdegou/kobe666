    <model name="inspection_robot">
        <pose>-1.35 -1.35 0.01 0 0 0</pose>
        <link name="base_footprint"/>
        <link name="base_link">
          <inertial>
            <pose>-0.064 0 0.048 0 0 0</pose>
            <inertia>
              <ixx>0.001</ixx>
              <ixy>0.000</ixy>
              <ixz>0.000</ixz>
              <iyy>0.001</iyy>
              <iyz>0.000</iyz>
              <izz>0.001</izz>
            </inertia>
            <mass>1.0</mass>
